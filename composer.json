{
    "name": "mr-rijal/ccavenue",
    "version": "1.0.0",
    "description": "Laravel package for CCAvenue payment gateway integration",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "ccavenue",
        "payment",
        "payment-gateway",
        "india"
    ],
    "homepage": "https://prashantrijal.com.np",
    "support": {
        "issues": "https://github.com/mr-rijal/ccavenue/issues",
        "source": "https://github.com/mr-rijal/ccavenue"
    },
    "authors": [
        {
            "name": "Prashant Rijal",
            "email": "prashant@prashantrijal.com.np",
            "homepage": "https://prashantrijal.com.np",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.9",
        "phpunit/phpunit": "^10.0|^11.0",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "MrRijal\\CCAvenue\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MrRijal\\CCAvenue\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit",
        "test:coverage": "@php vendor/bin/phpunit --coverage-html coverage",
        "check-style": "phpcs -p --standard=PSR12 src/ tests/",
        "fix-style": "phpcbf -p --standard=PSR12 src/ tests/",
        "pint": "pint"
    },
    "config": {
        "allow-plugins": {},
        "sort-packages": true,
        "prefer-stable": true,
        "optimize-autoloader": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        },
        "laravel": {
            "providers": [
                "MrRijal\\CCAvenue\\CCAvenueServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
